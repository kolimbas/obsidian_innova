      "id": "load-suppression",
      "name": "Load suppression",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1120, 460],
      "retryOnFail": true,
      "maxTries": 3,
      "notesInFlow": true,
      "notes": "OQ-2: merge of HubSpot do_not_email list + this manual sheet.",
      "credentials": { "googleSheetsOAuth2Api": { "id": "REPLACE_ME", "name": "gsheets-blincer-ops" } }
    },
    {
      "parameters": {
        "jsCode": "// Remove suppressed contacts from the segment.\nconst suppressed = new Set($('Load suppression').all().map(r => (r.json.email || '').toLowerCase()));\nreturn $('Resolve segment').all().filter(c => !suppressed.has((c.json.properties?.email || '').toLowerCase()));"
      },
      "id": "subtract-suppression",
      "name": "Subtract suppression",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 460]
    },
    {
      "parameters": {
        "operation": "lookup",
        "documentId": { "__rl": true, "value": "REPLACE_SHEET_ID", "mode": "id" },
        "sheetName": { "__rl": true, "value": "campaigns_log", "mode": "name" },
        "lookupColumn": "dedup_key",
        "lookupValue": "={{ $('Read campaign config').first().json.campaign_id }}-{{ $json.properties.hs_object_id }}",
        "options": {}
      },
      "id": "idempotency-lookup",
      "name": "Idempotency lookup",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1560, 460],
      "retryOnFail": true,
      "maxTries": 3,
      "credentials": { "googleSheetsOAuth2Api": { "id": "REPLACE_ME", "name": "gsheets-blincer-ops" } }
    },
    {
      "parameters": {
        "jsCode": "// Split recipients into send-now vs queue-for-tomorrow by daily_cap + send_window.\nconst cap = Number($('Read campaign config').first().json.daily_cap || 1500);\nconst all = $input.all();\nconst sendNow = all.slice(0, cap).map(i => ({ json: { ...i.json, _bucket: 'send_now' } }));\nconst queue = all.slice(cap).map(i => ({ json: { ...i.json, _bucket: 'queue' } }));\nreturn [...sendNow, ...queue];"
      },
      "id": "apply-caps",
      "name": "Apply caps & window",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 460]
    },
