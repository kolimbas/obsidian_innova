    {
      "parameters": {
        "operation": "read",
        "documentId": { "__rl": true, "value": "REPLACE_SHEET_ID", "mode": "id" },
        "sheetName": { "__rl": true, "value": "manual_suppression", "mode": "name" },
        "options": {}
